{
  "name": "ai-support-chatbot-qa-lab",
  "version": "1.0.0",
  "description": "Projeto de QA para testar comportamento, segurança e confiabilidade de um chatbot com IA.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:report": "jest --reporters=default --reporters=jest-html-reporter"
  },
  "keywords": [
    "qa",
    "ai-testing",
    "chatbot",
    "jest",
    "automation",
    "llm-testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "jest-html-reporter": "^4.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.0.0"
  },
  "jest-html-reporter": {
    "pageTitle": "AI Support Chatbot QA Lab - Test Report",
    "outputPath": "reports/test-report.html",
    "includeFailureMsg": true,
    "includeSuiteFailure": true
  }
}